{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BobaOrder",
  "description": "珍奶點餐 bot 的 LLM 輸出契約：型別、枚舉、必填欄位都在這裡定案；跨欄位的領域規則（例如數量上限）在 app/service.py 的 validate_business_rules。",
  "type": "object",
  "properties": {
    "status": { "enum": ["ok", "need_clarification"] },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": { "enum": ["珍珠奶茶", "紅茶拿鐵", "冬瓜茶", "四季春茶", "芋頭鮮奶"] },
          "size": { "enum": ["M", "L"] },
          "sweetness": { "enum": [0, 30, 50, 70, 100] },
          "ice": { "enum": ["正常冰", "少冰", "微冰", "去冰", "熱"] },
          "toppings": {
            "type": "array",
            "items": { "enum": ["珍珠", "波霸", "椰果", "仙草", "布丁"] },
            "uniqueItems": true
          },
          "quantity": { "type": "integer", "minimum": 1 }
        },
        "required": ["name", "size", "sweetness", "ice", "toppings", "quantity"],
        "additionalProperties": false
      }
    },
    "question": { "type": "string" },
    "notes": { "type": "string" }
  },
  "required": ["status"],
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "ok" } } },
      "then": { "required": ["items"] }
    },
    {
      "if": { "properties": { "status": { "const": "need_clarification" } } },
      "then": { "required": ["question"] }
    }
  ],
  "additionalProperties": false
}
